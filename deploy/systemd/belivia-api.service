[Unit]
Description=Belivia FastAPI
After=network.target

[Service]
User=beliviaapp
Group=beliviaapp
WorkingDirectory=/srv/belivia/backend
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=/etc/belivia/mail.env
ExecStart=/srv/belivia/backend/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
